<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="12dp"
    tools:ignore="HardcodedText">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/tvDisplay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="bottom|end"
            android:padding="24dp"
            android:text="0"
            android:textColor="#212121"
            android:textSize="64sp" />
    </androidx.cardview.widget.CardView>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4">


        <com.google.android.material.button.MaterialButton android:id="@+id/btnAC" style="@style/OperatorButtonStyle" android:layout_columnSpan="2" android:layout_columnWeight="3" android:text="AC" app:backgroundTint="#757575" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnBack" style="@style/OperatorButtonStyle" android:text="⌫" android:layout_columnSpan="2" app:backgroundTint="#E53935" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn7" android:text="7" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn8" android:text="8" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn9" android:text="9" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnDivide" android:text="/" style="@style/OperatorButtonStyle" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn4" android:text="4" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn5" android:text="5" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn6" android:text="6" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnMultiply" android:text="x" style="@style/OperatorButtonStyle" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn1" android:text="1" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn2" android:text="2" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn3" android:text="3" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnMinus" android:text="-" style="@style/OperatorButtonStyle" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btnDot" android:text="." style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn0" android:text="0" style="@style/NumericButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnPlus" android:text="+" style="@style/OperatorButtonStyle" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnEquals" android:text="=" style="@style/NumericButtonStyle" app:backgroundTint="#4CAF50" />


    </GridLayout>
</LinearLayout>