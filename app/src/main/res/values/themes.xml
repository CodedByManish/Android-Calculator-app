<resources>
    <style name="Theme.MyCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/bg_grey</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="BaseButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">63dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">22dp</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="CalcBtn.Function" parent="BaseButtonStyle">
        <item name="backgroundTint">@color/btn_function</item>
        <item name="android:textColor">#2A7F8A</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="CalcBtn.Operator" parent="BaseButtonStyle">
        <item name="backgroundTint">@color/btn_operator</item>
        <item name="android:textColor">#B39A47</item>
    </style>

    <style name="CalcBtn.Number" parent="BaseButtonStyle">
        <item name="backgroundTint">@color/btn_number</item>
        <item name="android:textColor">#8A8A8A</item>
    </style>

    <style name="CalcBtn.Clear" parent="BaseButtonStyle">
        <item name="backgroundTint">@color/btn_clear</item>
        <item name="android:textColor">#A6454A</item>
    </style>

    <style name="CalcBtn.Equals" parent="BaseButtonStyle">
        <item name="backgroundTint">@color/btn_equals</item>
        <item name="android:textColor">#4A8A57</item>
    </style>
</resources>